{
  "name": "naive-schema-form",
  "type": "module",
  "version": "0.0.16",
  "packageManager": "pnpm@10.11.0",
  "description": "Schema-driven form components for Naive UI.",
  "author": "songpeng <419626398@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/songpeng154/naive-schema-form",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/songpeng154/naive-schema-form.git"
  },
  "bugs": {
    "url": "https://github.com/songpeng154/naive-schema-form/issues"
  },
  "keywords": [
    "naive-ui",
    "vue",
    "vue3",
    "schema-form",
    "form",
    "dynamic-form",
    "typescript"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "playground": "vite",
    "typecheck": "vue-tsc --noEmit",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "naive-ui": "^2.44.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@vueuse/core": "^14.3.0",
    "es-toolkit": "^1.48.1",
    "type-fest": "^5.7.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tsdown/css": "^0.22.3",
    "@types/node": "^25.9.4",
    "@unocss/eslint-plugin": "^66.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  }
}
