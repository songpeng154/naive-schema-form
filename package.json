{
  "name": "naive-schema-form",
  "type": "module",
  "version": "0.0.7",
  "packageManager": "pnpm@10.11.0",
  "description": "Schema-driven form components for Naive UI.",
  "author": "songpeng <419626398@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/songpeng154/naive-schema-form",
  "repository": {},
  "bugs": {},
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "playground": "vite",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "naive-ui": "^2.44.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@vueuse/core": "^14.3.0",
    "es-toolkit": "^1.47.0",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tsdown/css": "^0.22.0",
    "@types/node": "^25.6.2",
    "@unocss/eslint-plugin": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^8.0.11",
    "vitepress": "^1.6.4",
    "vitepress-plugin-demo": "^0.8.1",
    "vitest": "^4.1.5",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.2.8"
  }
}
